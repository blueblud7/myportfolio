# Neon PostgreSQL connection string
# Get this from https://neon.tech after creating a project
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Session secret for JWT signing (use a long random string)
SESSION_SECRET=your-secret-key-here

# Finnhub API key (free tier 60 req/min) — earnings surprises fallback for Yahoo
# https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-key-here
