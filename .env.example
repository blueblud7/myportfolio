# Neon PostgreSQL connection string
# Get this from https://neon.tech after creating a project
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Session secret for JWT signing (use a long random string)
SESSION_SECRET=your-secret-key-here

# Finnhub API key (free tier 60 req/min) — earnings surprises fallback for Yahoo
# https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-key-here

# AES-256 master encryption key (32 bytes hex / 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ Never change after first use. Lost key = permanent data loss.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Vercel Cron secret — protects /api/cron/* routes
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-here

# Admin usernames (comma-separated, lowercase). Skips AI rate limits, can manually trigger fomo-agents stream.
ADMIN_USERNAMES=blueming,admin

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY hold the SAME public key value.
# Keep VAPID_PRIVATE_KEY secret (never commit). VAPID_SUBJECT is a mailto: contact.
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
